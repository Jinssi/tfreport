        "actions": ["update"],
        "before": {"name": "app"},
        "after": {"name": "app"}
      }
    },
    {
      "address": "azurerm_network_interface.web",
      "type": "azurerm_network_interface",
      "name": "web",
      "provider_name": "registry.terraform.io/hashicorp/azurerm",
      "change": {
        "actions": ["update"],
        "before": {"name": "web"},
        "after": {"name": "web"}
      }
    }
  ],
  "configuration": {
